# Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Node
node_modules/
.next/
out/
*.tsbuildinfo
apps/web/dev.log
apps/web/.playwright-mcp/
playwright-report/
test-results/

# Model artifacts and media: reproducible via ml/scripts/fetch_assets.py and
# ml/quantization/export_engines.py, and far too large for git.
ml/models/weights/
ml/models/engines/
# Artifacts downloaded from the MLflow registry by app/registry.py. Derived
# data with a registry as its source of truth, so committing it would be a
# second, staler copy of something already versioned elsewhere.
ml/models/_mlflow_cache/
apps/api/assets/*.mp4
apps/api/assets/*.avi
ml/data/raw/
ml/data/processed/
# Ultralytics downloads calibration datasets here on demand
datasets/
*.engine
*.onnx
*.pt

# Runtime state
apps/api/data/
mlflow.db
mlartifacts/
mlruns/
*.log
# Hydra writes a timestamped run directory on every invocation, including
# --dry-run. These are execution records, not source.
ml/train/outputs/
ml/quantization/reports/

# Environment and secrets
.env
.env.*
!.env.example

# Editors and OS
.vscode/
.idea/
.DS_Store
Thumbs.db
.claude/

# Stray stderr sidecars from Start-Process redirection
*.log.err

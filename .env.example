# Copy to .env at the repo root. Every setting is optional; these are the defaults.
# All are read with the STREAMSIGHT_ prefix by apps/api/app/core/config.py.

# --- inference --------------------------------------------------------------
# auto walks the fallback ladder; or name a backend: fp32_gpu, openvino_cpu, ...
STREAMSIGHT_DEFAULT_PRECISION=auto
STREAMSIGHT_DEFAULT_IMGSZ=640
STREAMSIGHT_DEGRADED_IMGSZ=480
STREAMSIGHT_CONF_THRESHOLD=0.25
STREAMSIGHT_IOU_THRESHOLD=0.45

# --- VRAM policy ------------------------------------------------------------
# Free VRAM measured after model load, below which the pipeline starts at
# DEGRADED_IMGSZ instead of failing later.
STREAMSIGHT_VRAM_FREE_FLOOR_MB=1200
STREAMSIGHT_VRAM_BUDGET_MB=3500

# --- streaming --------------------------------------------------------------
STREAMSIGHT_CAPTURE_MAX_WIDTH=1280
STREAMSIGHT_STREAM_MAX_WIDTH=1280
STREAMSIGHT_JPEG_QUALITY=80
STREAMSIGHT_RING_BUFFER_SIZE=30

# --- api --------------------------------------------------------------------
STREAMSIGHT_API_PORT=8100
STREAMSIGHT_MAX_UPLOAD_BYTES=33554432

# --- frontend ---------------------------------------------------------------
# Consumed by apps/web at build time.
NEXT_PUBLIC_API_BASE=http://localhost:8100
